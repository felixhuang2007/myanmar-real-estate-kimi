<!-- 搜索页 -->
<view class="search-page">
  <!-- 搜索栏 -->
  <view class="search-header">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input"
        type="text"
        placeholder="请输入小区名或地址"
        value="{{keywords}}"
        bindinput="onKeywordInput"
        bindconfirm="onSearchConfirm"
        focus
      />
      <text class="clear-icon" wx:if="{{keywords}}" bindtap="onKeywordInput" data-value="">✕</text>
    </view>
    <text class="cancel-btn" bindtap="wx.navigateBack">取消</text>
  </view>

  <!-- 搜索历史 -->
  <view class="search-history" wx:if="{{!keywords && historyKeywords.length > 0}}">
    <view class="history-header">
      <text class="history-title">搜索历史</text>
      <text class="clear-btn" bindtap="clearHistory">清除</text>
    </view>
    <view class="history-list">
      <text 
        class="history-item" 
        wx:for="{{historyKeywords}}" 
        wx:key="*this"
        bindtap="onHistoryTap"
        data-keyword="{{item}}"
      >{{item}}</text>
    </view>
  </view>

  <!-- 筛选和排序栏 -->
  <view class="filter-bar" wx:if="{{keywords || houses.length > 0}}">
    <view class="transaction-tabs">
      <text 
        class="tab {{transactionType === 'sale' ? 'active' : ''}}"
        bindtap="switchTransactionType"
        data-type="sale"
      >买房</text>
      <text 
        class="tab {{transactionType === 'rent' ? 'active' : ''}}"
        bindtap="switchTransactionType"
        data-type="rent"
      >租房</text>
    </view>
    
    <view class="filter-tabs">
      <text class="filter-tab" bindtap="toggleFilter">筛选 ▼</text>
      <text class="filter-tab" bindtap="changeSort" data-sort="default">综合排序</text>
      <text class="filter-tab" bindtap="changeSort" data-sort="price_asc">价格</text>
    </view>
  </view>

  <!-- 房源列表 -->
  <view class="house-list" wx:if="{{houses.length > 0}}">
    <view 
      class="house-card" 
      wx:for="{{houses}}" 
      wx:key="id"
      bindtap="onHouseTap"
      data-id="{{item.id}}"
    >
      <image class="house-image" src="{{item.images[0]}}" mode="aspectFill" />
      <view class="house-info">
        <text class="house-title text-ellipsis-2">{{item.title}}</text>
        <view class="house-tags">
          <text class="tag tag-primary" wx:if="{{item.verificationStatus === 'verified'}}">已验真</text>
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
        </view>
        <view class="house-meta">
          <text>{{item.rooms}} | {{item.area}}m² | {{item.district}}</text>
        </view>
        <view class="house-price">
          <text class="price">{{item.price}}</text>
          <text class="price-unit">{{item.priceUnit}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{isLoading}}">
    <text>加载中...</text>
  </view>

  <view class="empty" wx:if="{{!isLoading && houses.length === 0 && keywords}}">
    <image class="empty-image" src="/assets/images/empty.png" />
    <text>没有找到相关房源</text>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel {{showFilter ? 'show' : ''}}">
    <view class="filter-mask" bindtap="toggleFilter"></view>
    <view class="filter-content">
      <view class="filter-section">
        <text class="filter-title">区域</text>
        <view class="filter-options">
          <text 
            class="option {{districtCode === '' ? 'active' : ''}}"
            bindtap="selectDistrict"
            data-code=""
          >全部</text>
          <text 
            class="option {{districtCode === 'tamwe' ? 'active' : ''}}"
            bindtap="selectDistrict"
            data-code="tamwe"
          >Tamwe</text>
          <text 
            class="option {{districtCode === 'bahan' ? 'active' : ''}}"
            bindtap="selectDistrict"
            data-code="bahan"
          >Bahan</text>
        </view>
      </view>

      <view class="filter-section">
        <text class="filter-title">价格</text>
        <view class="filter-options">
          <text class="option" bindtap="selectPrice" data-min="0" data-max="5000">5000万以下</text>
          <text class="option" bindtap="selectPrice" data-min="5000" data-max="10000">5000-1亿</text>
          <text class="option" bindtap="selectPrice" data-min="10000" data-max="">1亿以上</text>
        </view>
      </view>

      <view class="filter-section">
        <text class="filter-title">户型</text>
        <view class="filter-options">
          <text class="option" bindtap="selectRoom" data-count="1">一室</text>
          <text class="option" bindtap="selectRoom" data-count="2">两室</text>
          <text class="option" bindtap="selectRoom" data-count="3">三室</text>
          <text class="option" bindtap="selectRoom" data-count="4">四室+</text>
        </view>
      </view>

      <view class="filter-actions">
        <button class="btn btn-default" bindtap="resetFilter">重置</button>
        <button class="btn btn-primary" bindtap="confirmFilter">确定</button>
      </view>
    </view>
  </view>
</view>