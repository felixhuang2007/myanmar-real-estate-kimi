<!-- 登录页 -->
<view class="login-page">
  <view class="login-header">
    <image class="logo" src="/assets/images/logo.png" />
    <text class="app-name">Myanmar Home</text>
    <text class="app-slogan">缅甸房产平台</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <text class="form-label">手机号</text>
      <view class="input-wrap">
        <text class="prefix">+95</text>
        <input 
          class="form-input"
          type="number"
          placeholder="请输入缅甸手机号"
          value="{{phone}}"
          bindinput="onPhoneInput"
          maxlength="15"
        />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">验证码</text>
      <view class="input-wrap code-wrap">
        <input 
          class="form-input"
          type="number"
          placeholder="请输入验证码"
          value="{{verifyCode}}"
          bindinput="onCodeInput"
          maxlength="6"
        />
        <button 
          class="code-btn {{countdown > 0 ? 'disabled' : ''}}"
          bindtap="sendCode"
          disabled="{{countdown > 0}}"
        >{{countdown > 0 ? countdown + 's' : '获取验证码'}}</button>
      </view>
    </view>

    <button 
      class="login-btn {{isLoading ? 'loading' : ''}}"
      bindtap="login"
      disabled="{{isLoading}}"
    >{{isLoading ? '登录中...' : '登录'}}</button>

    <view class="agreement">
      <text>登录即表示您同意</text>
      <text class="link">《用户协议》</text>
      <text>和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>
</view>