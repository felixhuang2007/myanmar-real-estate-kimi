/* 首页样式 */
.page-container {
  padding-bottom: 40rpx;
}

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
}

.city-selector {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.city-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow-down {
  font-size: 20rpx;
  color: #999;
  margin-left: 8rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-placeholder {
  font-size: 26rpx;
  color: #999;
}

/* Banner */
.banner-swiper {
  height: 300rpx;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

/* 快捷入口 */
.quick-entries {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
  background: #f0f7ff;
}

.entry-name {
  font-size: 26rpx;
  color: #333;
}

/* 区块标题 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-top: 24rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.more-link {
  font-size: 26rpx;
  color: #999;
}

/* 房源列表 */
.house-list {
  padding: 0 24rpx;
}

.house-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.house-image {
  width: 240rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background: #f5f5f5;
}

.house-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.house-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  line-height: 1.4;
}

.house-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.house-tags .tag {
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.house-meta {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.house-price {
  display: flex;
  align-items: baseline;
  margin-top: 12rpx;
}

.house-price .price {
  font-size: 36rpx;
  font-weight: bold;
  color: #f5222d;
}

.house-price .price-unit {
  font-size: 24rpx;
  color: #f5222d;
  margin-left: 8rpx;
}

/* 加载状态 */
.loading, .no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}