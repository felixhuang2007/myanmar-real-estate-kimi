# Myanmar Real Estate Platform - Production Environment Variables
# Copy this file to .env.prod and fill in real passwords (DO NOT commit .env.prod to git)

# Database Password
DB_PASSWORD=change_me_strong_password_here

# Redis Password
REDIS_PASSWORD=change_me_redis_password_here

# JWT Secret (generate a strong random string, at least 32 characters)
JWT_SECRET=change_me_very_long_random_jwt_secret_key_here_at_least_32_chars

# Optional: Server Configuration
# MYANMAR_PROPERTY_SERVER_PORT=8080
# MYANMAR_PROPERTY_ENVIRONMENT=production
